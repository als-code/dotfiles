# ~/.zshrc — symlink al repo dotfiles (ver ./install.sh)

# Solo en sesiones interactivas
[[ $- != *i* ]] && return

# Raíz del repo (resuelve el symlink ~/.zshrc → …/zsh/zshrc)
if [[ -z "${DOTFILES:-}" ]]; then
  _dotfiles_src="${(%):-%x}"
  [[ -L "$_dotfiles_src" ]] && _dotfiles_src="$(readlink -f "$_dotfiles_src")"
  export DOTFILES="$(cd "$(dirname "$_dotfiles_src")/.." && pwd)"
  unset _dotfiles_src
fi

# Historial
HISTSIZE=5000
SAVEHIST=10000
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_REDUCE_BLANKS
setopt SHARE_HISTORY
setopt APPEND_HISTORY

# Editor por defecto
export EDITOR="${EDITOR:-nvim}"
export VISUAL="$EDITOR"
export SUDO_EDITOR="$EDITOR"

# Oh My Zsh
export ZSH="${ZSH:-$HOME/.oh-my-zsh}"
ZSH_THEME="agnoster"

# zsh-syntax-highlighting debe ir al final del array de plugins
plugins=(
  git
  zsh-autosuggestions
  zsh-syntax-highlighting
)

# Sugerencias del historial (gris) — flecha derecha acepta
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=240'

source "$ZSH/oh-my-zsh.sh"

# Aliases y funciones compartidos con bash
if [[ -f "$DOTFILES/bash/bash_aliases" ]]; then
  source "$DOTFILES/bash/bash_aliases"
fi
